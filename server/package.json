{
  "name": "gastar-app-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-unit-tests.js",
    "test:coverage": "node scripts/run-unit-tests.js --coverage && node scripts/run-integration-tests.js --coverage",
    "test:integration": "node scripts/run-integration-tests.js",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "db:generate": "prisma generate",
    "lint": "eslint src test scripts",
    "lint:fix": "eslint src test scripts --fix"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "resend": "^6.9.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "dotenv-cli": "^7.4.2",
    "nodemon": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
