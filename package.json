{
  "name": "gastar-app",
  "version": "1.0.0",
  "description": "Personal finance tracker",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "sonar": "sonar",
    "start": "npm --prefix server start",
    "test": "npm --prefix server test",
    "test:integration": "npm --prefix server run test:integration",
    "db:migrate": "npm --prefix server run db:migrate",
    "db:studio": "npm --prefix server run db:studio",
    "install:all": "npm install && npm --prefix client install && npm --prefix server install",
    "lint": "eslint server/src server/test client/src",
    "lint:fix": "eslint server/src server/test client/src --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "typecheck": "npm --prefix server run typecheck && npm --prefix client run typecheck",
    "typecheck:server": "npm --prefix server run typecheck",
    "typecheck:client": "npm --prefix client run typecheck",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,md}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  }
}
